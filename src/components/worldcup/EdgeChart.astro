---
// src/components/worldcup/EdgeChart.astro
// Sorted horizontal bars per team: Model / Polymarket / Kalshi / Blended.
// Polymarket and Kalshi are each de-vigged separately, so they sit on the same
// scale as the model and blend. The model-vs-consensus disagreement is flagged.
import type { Snapshot, Forecast } from "../../lib/worldcup-types";
interface Props { snapshot: Snapshot; top?: number }
const { snapshot, top = 16 } = Astro.props;
const rows = snapshot.forecasts.slice(0, top);
const mkt = (team: string) => snapshot.market[team];

const series: { label: string; color: string; get: (f: Forecast) => number | null }[] = [
  { label: "Model",      color: "var(--accent)", get: (f) => f.model_pct },
  { label: "Polymarket", color: "#a78bfa",       get: (f) => mkt(f.team)?.polymarket ?? null },
  { label: "Kalshi",     color: "#f59e0b",       get: (f) => mkt(f.team)?.kalshi ?? null },
  { label: "Blended",    color: "var(--green)",  get: (f) => f.blended_pct },
];

const allVals = rows.flatMap((f) => series.map((s) => s.get(f)))
                    .filter((v): v is number => v != null);
const max = Math.max(0.01, ...allVals);
const pct = (v: number) => `${(v * 100).toFixed(1)}%`;
const w = (v: number) => `${(v / max) * 100}%`;
---
<div class="wc-edge">
  <div class="wc-legend mono">
    {series.map((s) => (
      <span class="wc-legend-item"><i style={`background:${s.color}`}></i>{s.label}</span>
    ))}
    <span class="wc-legend-item wc-legend-edge">▲ = model above market consensus</span>
  </div>
  {rows.map((f) => {
    const edge = f.model_pct - f.market_pct;
    return (
      <div class="wc-edge-row">
        <div class="wc-edge-team">
          <span class="wc-team-name">{f.team}</span>
          {edge > 0.01 && <span class="wc-edge-flag" title={`+${pct(edge)} vs consensus`}>▲ {pct(edge)}</span>}
        </div>
        <div class="wc-bars">
          {series.map((s) => {
            const v = s.get(f);
            return (
              <div class="wc-bar-track">
                <span class="wc-bar-tag mono" style={`color:${s.color}`}>{s.label.slice(0, 4)}</span>
                {v == null
                  ? <div class="wc-bar wc-bar-empty"></div>
                  : <div class="wc-bar" style={`width:${w(v)}; background:${s.color}`}></div>}
                <span class="wc-bar-val mono">{v == null ? "—" : pct(v)}</span>
              </div>
            );
          })}
        </div>
      </div>
    );
  })}
</div>
<style>
  .wc-edge { display: flex; flex-direction: column; gap: 14px; }
  .wc-legend { display: flex; flex-wrap: wrap; gap: 14px; font-size: 0.75rem; color: var(--muted); }
  .wc-legend-item { display: inline-flex; align-items: center; gap: 6px; }
  .wc-legend-item i { width: 10px; height: 10px; border-radius: 2px; display: inline-block; }
  .wc-legend-edge { color: var(--green); }
  .wc-edge-row {
    display: grid; grid-template-columns: 130px 1fr; gap: 12px; align-items: center;
    padding: 10px 0; border-bottom: 1px solid var(--border);
  }
  .wc-edge-team { display: flex; flex-direction: column; gap: 2px; }
  .wc-team-name { font-weight: 600; }
  .wc-edge-flag { font-size: 0.72rem; color: var(--green); }
  .wc-bars { display: flex; flex-direction: column; gap: 4px; }
  .wc-bar-track { display: flex; align-items: center; gap: 8px; }
  .wc-bar-tag { width: 34px; font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.03em; flex-shrink: 0; opacity: 0.85; }
  .wc-bar { height: 9px; border-radius: 5px; min-width: 2px; transition: width 0.3s ease; }
  .wc-bar-empty { min-width: 0; background: transparent; }
  .wc-bar-val { font-size: 0.72rem; color: var(--muted); min-width: 48px; }
  @media (max-width: 540px) { .wc-edge-row { grid-template-columns: 1fr; } }
</style>
