---
import { WORLD_LAND_PATH } from "../data/world-land";

interface Pin {
  href: string;
  title: string;
  mapX: number; // % of map width
  mapY: number; // % of map height
}
interface Props { pins: Pin[]; }
const { pins } = Astro.props;

// --- Static zoom -------------------------------------------------------------
// Land is drawn in a full-world equirectangular viewBox (x:0-100 = lng -180..180,
// y:0-50 = lat 90..-90). We crop to a 2:1 sub-window to zoom in, and remap each
// pin into that window so it stays aligned with the land. Tweak these two:
const ZOOM = 1.4;                 // 1 = whole world; raise to zoom in more
const FOCUS = { x: 38, y: 20 };   // view centre in world coords (x:0-100, y:0-50)

const vw = 100 / ZOOM;
const vh = 50 / ZOOM;             // keeps the container's 2:1 aspect
const vx = Math.max(0, Math.min(100 - vw, FOCUS.x - vw / 2));
const vy = Math.max(0, Math.min(50 - vh, FOCUS.y - vh / 2));
const viewBox = `${vx} ${vy} ${vw} ${vh}`;
const gridStroke = 0.15 / ZOOM;   // keep stroke weight constant across zoom levels
const landStroke = 0.12 / ZOOM;

// pin (mapX% width, mapY% height of full world) -> position within the window
const placed = pins.map((p) => ({
  ...p,
  left: ((p.mapX - vx) / vw) * 100,
  top: ((p.mapY * 0.5 - vy) / vh) * 100,
}));
---
<div class="trip-map" role="group" aria-label="Map of trips">
  <!-- Stylized world map. Decorative; pins are the interactive layer.
       Land = Natural Earth 110m, projected equirectangular (see src/data/world-land.ts),
       so pin mapX/mapY (lng/lat as %) land on the right continents. -->
  <svg class="trip-map__bg" viewBox={viewBox} preserveAspectRatio="none" aria-hidden="true">
    <path class="trip-map__land" d={WORLD_LAND_PATH} stroke-width={landStroke} />
    <g class="trip-map__grid" stroke="var(--border-hi)" stroke-width={gridStroke} fill="none" opacity="0.4">
      <line x1="0" y1="12.5" x2="100" y2="12.5" />
      <line x1="0" y1="25"   x2="100" y2="25" />
      <line x1="0" y1="37.5" x2="100" y2="37.5" />
      <line x1="16.6" y1="0" x2="16.6" y2="50" />
      <line x1="33.3" y1="0" x2="33.3" y2="50" />
      <line x1="50"   y1="0" x2="50"   y2="50" />
      <line x1="66.6" y1="0" x2="66.6" y2="50" />
      <line x1="83.3" y1="0" x2="83.3" y2="50" />
    </g>
  </svg>

  {placed.map((p) => (
    <a class={`trip-pin${p.left > 85 ? " trip-pin--flip" : ""}`} href={p.href} aria-label={p.title} style={`left:${p.left}%; top:${p.top}%`}>
      <span class="trip-pin__dot"></span>
      <span class="trip-pin__label">{p.title}</span>
    </a>
  ))}
</div>

<style>
  .trip-map {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 1;
    background:
      radial-gradient(55% 75% at 50% 35%, rgba(91,140,255,0.12), transparent 70%),
      var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .trip-map__bg   { position: absolute; inset: 0; width: 100%; height: 100%; }
  .trip-map__land {
    fill: rgba(140,165,255,0.08);
    stroke: rgba(150,175,255,0.32);
    stroke-linejoin: round;
  }

  /* The pin box is exactly the dot, so translate(-50%,-50%) centers the DOT on
     the (mapX%, mapY%) point. The label is positioned absolutely beside it so it
     never adds width to the pin (which would shove the dot off the coordinate). */
  .trip-pin {
    position: absolute;
    width: 14px;
    height: 14px;
    transform: translate(-50%, -50%);
    z-index: 1;
  }
  .trip-pin__dot {
    display: block;            /* span is inline by default — block makes width/height/radius apply */
    width: 14px; height: 14px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--ring); /* light ring for contrast against the dark map */
    box-shadow: 0 0 0 4px rgba(91,140,255,0.30), 0 0 18px 5px rgba(91,140,255,0.75);
    animation: pin-pulse 2.4s ease-in-out infinite;
  }
  .trip-pin__label {
    position: absolute;
    left: 18px;
    top: 50%;
    font-family: var(--font-display);
    font-size: 0.72rem;
    color: var(--text);
    background: rgba(8,8,11,0.72);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(-50%) translateX(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease;
    pointer-events: none;
  }
  .trip-pin:hover .trip-pin__label,
  .trip-pin:focus-visible .trip-pin__label {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }
  /* Pins near the right edge open their label to the LEFT so it isn't clipped
     by the map's overflow:hidden. */
  .trip-pin--flip .trip-pin__label {
    left: auto;
    right: 18px;
    transform: translateY(-50%) translateX(4px);
  }
  .trip-pin--flip:hover .trip-pin__label,
  .trip-pin--flip:focus-visible .trip-pin__label {
    transform: translateY(-50%) translateX(0);
  }

  @keyframes pin-pulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(91,140,255,0.30), 0 0 18px 5px rgba(91,140,255,0.65); }
    50%      { box-shadow: 0 0 0 8px rgba(91,140,255,0.14), 0 0 28px 7px rgba(91,140,255,0.9); }
  }
  @media (prefers-reduced-motion: reduce) {
    .trip-pin__dot { animation: none; }
  }
</style>
