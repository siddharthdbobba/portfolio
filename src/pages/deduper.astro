---
import Base from "../layouts/Base.astro";
---

<Base
  title="DeDuper — Remove Duplicate Photos"
  description="Find and remove duplicate photos from your library using on-device AI. Private, fast, and built for macOS and iOS."
>
  <main>

    <!-- ─── Hero ──────────────────────────────────────────────────────── -->
    <section class="section hero-section">
      <div class="container">
        <div class="app-badge-row">
          <span class="platform-badge">macOS</span>
          <span class="platform-badge">iOS</span>
          <span class="platform-badge beta-badge">Beta</span>
        </div>

        <div class="app-hero-row">
          <div class="app-icon-lg">✦</div>
          <div>
            <h1>DeDuper</h1>
            <p class="lead" style="margin-top: 8px; max-width: 480px;">
              Find and remove duplicate photos from your library using on-device AI. Private, fast, and actually reliable.
            </p>
          </div>
        </div>

        <div class="hero-links">
          <a class="btn btn-primary" href="#download">Download Free</a>
          <a class="btn btn-secondary" href="#features">See how it works</a>
        </div>

        <p class="hero-fine mono muted">Free &amp; open source · macOS 14+</p>
      </div>
    </section>

    <!-- ─── Screenshot placeholder ───────────────────────────────────── -->
    <section class="section screenshot-section">
      <div class="container">
        <div class="screenshot-frame">
          <div class="screenshot-placeholder">
            <span class="mono muted" style="font-size: 0.85rem;">screenshots coming soon_</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Download ────────────────────────────────────────────────── -->
    <section class="section" id="download">
      <div class="container">
        <h2 style="margin-bottom: 8px;">Download</h2>
        <p style="margin-bottom: 32px; max-width: 480px;">
          DeDuper is completely free and open source — every feature included, no accounts, no payments.
          Scan, review, and delete duplicates (with AI-powered close-call resolution) entirely on your Mac.
        </p>

        <div class="download-box card">
          <div class="download-meta">
            <div class="download-icon">✦</div>
            <div>
              <div class="download-name">DeDuper <span class="mono muted" style="font-size: 0.8rem;">beta</span></div>
              <div class="download-req mono muted">macOS 14 Sonoma or later · Apple Silicon &amp; Intel</div>
            </div>
          </div>
          <a class="btn btn-primary" href="https://github.com/siddharthdbobba/PhotoDeduper/releases/latest" target="_blank">
            Download .dmg
          </a>
        </div>

        <div class="gatekeeper-note card" style="margin-top: 16px;">
          <strong>First launch on macOS:</strong> If you see "DeDuper can't be opened because it is from an unidentified developer," right-click the app and choose <strong>Open</strong> — then click Open in the dialog. This is a one-time step for apps distributed outside the Mac App Store.
        </div>
      </div>
    </section>

    <!-- ─── Features ─────────────────────────────────────────────────── -->
    <section class="section" id="features">
      <div class="container">
        <h2 style="margin-bottom: 8px;">How it works</h2>
        <p style="margin-bottom: 40px; max-width: 480px;">
          DeDuper scans your photo library in seconds, groups near-identical shots, and uses AI to pick the best one — so you don't have to.
        </p>

        <div class="features-grid">
          <div class="feature-card card">
            <div class="feature-icon">🔍</div>
            <h3>Perceptual hashing</h3>
            <p>Catches exact duplicates and near-duplicates even across different exports, screenshots, and edits.</p>
          </div>

          <div class="feature-card card">
            <div class="feature-icon">🤖</div>
            <h3>AI close-call resolution</h3>
            <p>When two photos are too similar to call, GPT-4.1 mini picks the sharper, better-composed shot automatically.</p>
          </div>

          <div class="feature-card card">
            <div class="feature-icon">🔒</div>
            <h3>Fully on-device</h3>
            <p>Your photos never leave your device unless you opt in to AI review. No cloud uploads, no accounts required.</p>
          </div>

          <div class="feature-card card">
            <div class="feature-icon">📂</div>
            <h3>Photos.app &amp; folders</h3>
            <p>Scans your Apple Photos library and any local folder. Works wherever your photos live.</p>
          </div>

          <div class="feature-card card">
            <div class="feature-icon">🛡️</div>
            <h3>Protected albums</h3>
            <p>Mark albums as off-limits. Favorites are always protected automatically — DeDuper will never touch them.</p>
          </div>

          <div class="feature-card card">
            <div class="feature-icon">📋</div>
            <h3>Audit log</h3>
            <p>Every deletion is logged with photo name, size, and timestamp. Export to CSV anytime.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Free & open source ──────────────────────────────────────────── -->
    <section class="section" id="open-source">
      <div class="container">
        <h2 style="margin-bottom: 8px;">Free &amp; open source</h2>
        <p style="margin-bottom: 32px; max-width: 480px;">
          DeDuper is 100% free, with every feature unlocked — no tiers, no subscription, no in-app purchases.
          The full source is public on GitHub, so you can see exactly what runs on your photos,
          build it yourself, or contribute.
        </p>

        <div class="download-box card">
          <div class="download-meta">
            <div class="download-icon">★</div>
            <div>
              <div class="download-name">Open source on GitHub</div>
              <div class="download-req mono muted">Public repository · contributions welcome</div>
            </div>
          </div>
          <a class="btn btn-primary" href="https://github.com/siddharthdbobba/PhotoDeduper" target="_blank">
            View source
          </a>
        </div>
      </div>
    </section>

    <!-- ─── FAQ ───────────────────────────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <h2 style="margin-bottom: 32px;">FAQ</h2>
        <div class="faq-list">
          <div class="faq-item">
            <h3 class="faq-q">Does it delete photos automatically?</h3>
            <p class="faq-a">No. DeDuper always shows you what it found before deleting anything. You can also turn on "Hold for review" to move flagged photos to a review album in Photos instead of deleting them outright.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-q">Does the AI see my photos?</h3>
            <p class="faq-a">Only if you turn on AI close-call resolution. In that case, thumbnail-sized crops are sent to GPT-4.1 mini to pick the better photo. With it off, DeDuper does everything on-device.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-q">What counts as a duplicate?</h3>
            <p class="faq-a">Photos taken within a configurable time window (default 30 seconds) that are visually similar based on perceptual hashing. You control the sensitivity — conservative, balanced, or aggressive.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-q">Does it work with RAW or HEIC photos?</h3>
            <p class="faq-a">Yes. DeDuper supports HEIC, JPG, PNG, and RAW formats. It can also find HEIC↔JPG cross-format duplicates when that option is enabled.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-q">macOS says it can't be opened — what do I do?</h3>
            <p class="faq-a">Right-click (or Control-click) the DeDuper app and choose <strong>Open</strong>. Click Open in the dialog that appears. This is a one-time step — macOS will remember your choice. This prompt appears for apps distributed outside the Mac App Store that aren't yet notarized.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-q">Is DeDuper really free?</h3>
            <p class="faq-a">Yes — completely. DeDuper is free and open source, with every feature included. There's no paid tier, no subscription, and no in-app purchases. The full source is public on GitHub, so you can review it, build it yourself, or contribute.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Back ───────────────────────────────────────────────────────── -->
    <section class="section back-section">
      <div class="container" style="text-align: center;">
        <a class="btn btn-secondary" href="/">← Back to portfolio</a>
      </div>
    </section>

  </main>
</Base>

<style>
  /* Hero */
  .hero-section    { padding-top: 80px; padding-bottom: 64px; }
  .app-badge-row   { display: flex; gap: 8px; margin-bottom: 24px; }
  .platform-badge  {
    padding: 3px 10px;
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: 0.75rem;
    color: var(--muted);
    font-family: "SF Mono", "Fira Code", monospace;
  }
  .beta-badge {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Download */
  .download-box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    max-width: 560px;
  }
  .download-meta   { display: flex; align-items: center; gap: 16px; }
  .download-icon   {
    width: 44px; height: 44px; flex-shrink: 0;
    background: var(--accent);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem; color: white;
  }
  .download-name   { font-weight: 600; font-size: 1rem; color: var(--text); margin-bottom: 2px; }
  .download-req    { font-size: 0.78rem; }
  .gatekeeper-note {
    max-width: 560px;
    font-size: 0.85rem;
    line-height: 1.6;
    border-left: 3px solid var(--border);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  @media (max-width: 500px) {
    .download-box { flex-direction: column; align-items: flex-start; }
  }
  .app-hero-row    { display: flex; align-items: center; gap: 24px; margin-bottom: 28px; }
  .app-icon-lg     {
    width: 72px; height: 72px; flex-shrink: 0;
    background: var(--accent);
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem; color: white;
  }
  .hero-links      { display: flex; flex-wrap: wrap; gap: 12px; }
  .hero-fine       { margin-top: 16px; font-size: 0.8rem; }

  /* Screenshot */
  .screenshot-section { padding-top: 0; }
  .screenshot-frame {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .screenshot-placeholder {
    background: var(--bg-card);
    height: 360px;
    display: flex; align-items: center; justify-content: center;
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .feature-card  { display: flex; flex-direction: column; gap: 10px; }
  .feature-icon  { font-size: 1.5rem; }

  /* FAQ */
  .faq-list  { display: flex; flex-direction: column; gap: 0; }
  .faq-item  { padding: 20px 0; border-bottom: 1px solid var(--border); }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-q     { font-size: 1rem; font-weight: 600; margin-bottom: 8px; color: var(--text); }
  .faq-a     { font-size: 0.9rem; max-width: 560px; }

  /* Back */
  .back-section { padding-top: 32px; padding-bottom: 48px; }

  /* Responsive */
  @media (max-width: 700px) {
    .features-grid { grid-template-columns: 1fr; }
    .app-hero-row  { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 480px) {
    .hero-section { padding-top: 48px; }
    .features-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
