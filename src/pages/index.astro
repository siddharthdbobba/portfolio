---
import '../styles/homepage.css';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Siddharth Bobba · Native, on-device AI apps</title>
<meta name="description" content="My name is Siddharth Bobba. I study Computer and Information Technology and Economics at Purdue, and I build native macOS and iOS apps powered by on-device AI." />
<link rel="canonical" href="https://siddharthbobba.com/" />

<!-- Open Graph -->
<meta property="og:title"       content="Siddharth Bobba · Native, on-device AI apps" />
<meta property="og:description" content="My name is Siddharth Bobba. I study Computer and Information Technology and Economics at Purdue, and I build native macOS and iOS apps powered by on-device AI." />
<meta property="og:type"        content="website" />
<meta property="og:url"         content="https://siddharthbobba.com/" />
<meta property="og:image"       content="https://siddharthbobba.com/og-card.png" />

<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content="Siddharth Bobba · Native, on-device AI apps" />
<meta name="twitter:description" content="My name is Siddharth Bobba. I study Computer and Information Technology and Economics at Purdue, and I build native macOS and iOS apps powered by on-device AI." />
<meta name="twitter:image"       content="https://siddharthbobba.com/og-card.png" />

<!-- Favicons -->
<link rel="icon" href="/favicon.ico?v=3" sizes="48x48" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" id="favicon" />
<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png?v=3" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=3" />
</head>
<body>

  <!-- background textures -->
  <div class="bg-layer bg-aurora"></div>
  <div class="bg-layer bg-grid"></div>
  <div class="bg-layer bg-grain"></div>
  <div id="cursor-glow"></div>

  <!-- nav -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="#top" class="brand" aria-label="sb home">sb_<span class="caret"></span></a>
      <div class="nav-links">
        <a href="#experience"><span class="hash">#</span> experience</a>
        <a href="#work"><span class="hash">#</span> projects</a>
        <a href="/trips/"><span class="hash">#</span> trips</a>
        <a href="#about"><span class="hash">#</span> about</a>
        <a href="#contact"><span class="hash">#</span> contact</a>
      </div>
      <div class="nav-right">
        <span class="nav-cmd"><kbd>⌘</kbd><kbd>S</kbd> jump to…</span>
        <a href="#contact" class="btn btn-primary btn-sm">say hi <span class="arrow">→</span></a>
      </div>
    </div>
  </nav>

  <main id="top">

    <!-- ===================== HERO ===================== -->
    <header class="hero" data-screen-label="Hero">
      <canvas id="hero-canvas" aria-hidden="true"></canvas>
      <div class="hero-content">
        <h1>Siddharth<br /><span class="grad">Bobba.</span></h1>
        <div class="typed-wrap">
          <span class="prompt">~ $</span>
          <span id="typed"></span><span class="typed-cursor" id="typed-cursor"></span>
        </div>
        <div class="hero-cta">
          <a href="#contact" class="btn btn-primary">Email me <span class="arrow">→</span></a>
          <a href="#work" class="btn btn-ghost">View the work</a>
        </div>
      </div>
      <a href="#status" class="scroll-hint" aria-label="scroll down">
        <span>scroll</span>
        <span class="line"></span>
      </a>
    </header>

    <!-- ===================== LIVE STATUS ===================== -->
    <section class="statusbar" id="status" aria-label="live status">
      <div class="statusbar-track">
        <span class="chip"><span class="live"></span><span class="k">interning</span> <b>@ Lockheed Martin · AI + Cloud</b></span>
        <span class="chip"><span class="k">consulting</span> <b>@ Boilermaker Consulting</b></span>
        <span class="chip"><span class="k">building</span> <b>DeDuper 2.0</b></span>
        <span class="chip" id="commit-chip" hidden><span class="k">last commit</span> <b id="last-commit">—</b></span>
        <span class="chip"><span class="k">based in</span> <b>San Francisco, CA</b></span>
        <span class="chip"><span class="k">local</span> <b id="clock">—</b></span>
      </div>
    </section>

    <!-- ===================== EXPERIENCE ===================== -->
    <section class="experience" id="experience" data-screen-label="Experience" aria-label="Experience">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">experience</span>
          <h2>Turning messy data<br />into decisions.</h2>
          <p class="sub">AI and data science across enterprise, research, and consulting.</p>
        </div>

        <div class="exp-list">

          <article class="exp-item reveal">
            <div class="exp-meta">
              <div class="exp-co"><img src="/assets/logo-lockheed-clean.png" class="exp-logo" alt="" />Lockheed Martin</div>
              <div class="exp-role">AI + Cloud Intern <span class="exp-now">current</span></div>
              <div class="exp-when">May 2026 &ndash; Present · prev. Data Science Intern, Summer 2025</div>
            </div>
            <div class="exp-body">
              <ul class="exp-points">
                <li>Building <b>AI agents</b> that answer questions over local, on-network information. All the retrieval and reasoning runs on data that can&rsquo;t leave the enterprise.</li>
                <li>Deploying and scaling those agent services on <b>Kubernetes</b> and <b>AWS EC2</b>, and owning the whole path from prototype to running infrastructure.</li>
                <li>Last summer (2025), I launched a full-stack <b>AI reporting tool</b> in Python that saved <b>50+ managers over 100 hours a week</b>, along with 10+ executive Tableau dashboards.</li>
              </ul>
              <div class="card-tags">
                <span class="tag">AI agents</span>
                <span class="tag">Python</span>
                <span class="tag">Kubernetes</span>
                <span class="tag">AWS EC2</span>
              </div>
            </div>
          </article>

          <article class="exp-item reveal" data-delay="1">
            <div class="exp-meta">
              <div class="exp-co"><img src="/assets/logo-boilermaker.png" class="exp-logo" alt="" />Boilermaker Consulting</div>
              <div class="exp-role">Consultant <span class="exp-now">current</span></div>
              <div class="exp-when">Jan 2026 &ndash; Present · West Lafayette, IN</div>
            </div>
            <div class="exp-body">
              <ul class="exp-points">
                <li>Built a <b>data-driven market-entry strategy</b> supporting expansion across 5 states.</li>
                <li>Segmented high-probability customer groups and modeled pricing and positioning to accelerate projected revenue.</li>
                <li>Delivered implementation-ready recommendations and launch assets for near-term execution.</li>
              </ul>
              <div class="card-tags">
                <span class="tag">data strategy</span>
                <span class="tag">segmentation</span>
                <span class="tag">analytics</span>
              </div>
            </div>
          </article>

          <article class="exp-item reveal" data-delay="2">
            <div class="exp-meta">
              <div class="exp-co"><img src="/assets/logo-wwf.png" class="exp-logo" alt="" />World Wildlife Fund</div>
              <div class="exp-role">Data Science Researcher</div>
              <div class="exp-when">Aug 2025 &ndash; May 2026 · West Lafayette, IN</div>
            </div>
            <div class="exp-body">
              <ul class="exp-points">
                <li>Built and standardized <b>3 sensor-data pipelines</b> feeding a cloud data lakehouse.</li>
                <li>Audited the project&rsquo;s <b>Terraform</b> infrastructure and proposed 5+ improvements to modularity and maintainability.</li>
                <li>Recommended <b>DataPlex</b>-based governance to scale the data architecture.</li>
              </ul>
              <div class="card-tags">
                <span class="tag">Terraform</span>
                <span class="tag">DataPlex</span>
                <span class="tag">data pipelines</span>
                <span class="tag">lakehouse</span>
              </div>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ===================== WORK ===================== -->
    <section class="projects" id="work" data-screen-label="Work" aria-label="Projects">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">projects</span>
          <h2>Things I build<br />on my own time.</h2>
          <p class="sub">Native Apple apps and web experiments. This is where I try out ideas and chase the little details that make software feel good.</p>
        </div>

        <div class="proj-grid">

          <!-- FEATURED: DeDuper -->
          <article class="card featured reveal" data-tilt>
            <div class="card-grid2">
              <div class="card-cover">
                <img src="/assets/deduper-review.png" alt="DeDuper screenshot" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
              </div>
              <div class="card-body card-inner">
                <div class="card-eyebrow">
                  <span>01 / flagship</span>
                  <span class="card-badge">macOS · iOS</span>
                </div>
                <h3>DeDuper</h3>
                <p>An on-device photo de-duper. It uses a local vision model to find near-duplicate shots, so nothing ever leaves your Mac or phone. I built it because I believe powerful AI shouldn&rsquo;t have to cost you your privacy.</p>
                <div class="card-tags">
                  <span class="tag">Swift</span>
                  <span class="tag">CoreML</span>
                  <span class="tag">Vision</span>
                  <span class="tag">embeddings</span>
                  <span class="tag">on-device</span>
                </div>
                <a href="/deduper/" class="card-link">Learn more <span class="arrow">→</span></a>
              </div>
            </div>
          </article>

          <!-- Sticker Map -->
          <article class="card reveal" data-delay="1" data-tilt>
            <div class="card-cover">
              <div class="cover-canvas" id="cover-sticker" aria-hidden="true"></div>
              <div class="cover-fade"></div>
            </div>
            <div class="card-body card-inner">
              <div class="card-eyebrow">
                <span>02 / web</span>
                <span class="card-badge">Web app</span>
              </div>
              <h3>Sticker Map</h3>
              <p>A map where people drop stickers on the places they love. I wanted something that brings people together around the spots that matter to them. It&rsquo;s real-time, shareable, and honestly a little addictive.</p>
              <div class="card-tags">
                <span class="tag">TypeScript</span>
                <span class="tag">MapLibre</span>
                <span class="tag">Cloudflare</span>
              </div>
              <a href="https://stickers.siddharthbobba.com" class="card-link" target="_blank" rel="noopener">stickers.siddharthbobba.com <span class="arrow">→</span></a>
            </div>
          </article>

          <!-- World Cup Predictor -->
          <article class="card reveal" data-delay="2" data-tilt>
            <div class="card-cover">
              <div class="cover-canvas" id="cover-bracket" aria-hidden="true"></div>
              <div class="cover-fade"></div>
            </div>
            <div class="card-body card-inner">
              <div class="card-eyebrow">
                <span>03 / web</span>
                <span class="card-badge locked">🔒 private</span>
              </div>
              <h3>World Cup Predictor</h3>
              <p>A bracket game with a probabilistic model doing the picking. Password-gated while it&rsquo;s in season, but I&rsquo;m happy to walk you through it.</p>
              <div class="card-tags">
                <span class="tag">Python</span>
                <span class="tag">Astro</span>
                <span class="tag">stats</span>
              </div>
              <a href="#contact" class="card-link">Request access <span class="arrow">→</span></a>
            </div>
          </article>

          <!-- Trips -->
          <article class="card reveal" data-delay="1" data-tilt>
            <div class="card-cover">
              <div class="cover-canvas" id="cover-trips" aria-hidden="true"></div>
              <div class="cover-fade"></div>
            </div>
            <div class="card-body card-inner">
              <div class="card-eyebrow">
                <span>04 / iOS</span>
                <span class="card-badge">iOS</span>
              </div>
              <h3>Trips</h3>
              <p>A quiet travel log. Routes, photos, and the notes you actually want to keep, stitched into a timeline worth coming back to. The iOS app is still in the works, but the log is live.</p>
              <div class="card-tags">
                <span class="tag">Swift</span>
                <span class="tag">MapKit</span>
                <span class="tag">SwiftData</span>
              </div>
              <a href="/trips/" class="card-link">See the trips <span class="arrow">→</span></a>
            </div>
          </article>

          <!-- one more half-width spacer card: GitHub callout -->
          <article class="card reveal" data-delay="2" data-tilt>
            <div class="card-body card-inner" style="padding:40px;">
              <div class="card-eyebrow"><span>+ more</span></div>
              <h3>Always building.</h3>
              <p>Experiments, small tools, and half-finished ideas all live on GitHub. I learn best by making things.</p>
              <a href="https://github.com/siddharthdbobba" class="card-link" target="_blank" rel="noopener">github.com/siddharthdbobba <span class="arrow">→</span></a>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ===================== ABOUT ===================== -->
    <section class="about" id="about" data-screen-label="About" aria-label="About">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">about</span>
        </div>
        <div class="about-grid">
          <div class="about-body reveal">
            <p class="about-quote">I like shipping <span class="grad">small, fast, opinionated</span> software that respects your time and your data.</p>
            <p>My name is Siddharth Bobba, and I&rsquo;m a student at <span class="lite">Purdue</span> studying Computer and Information Technology and Economics, with a focus on AI. I work at the <span class="lite">intersection of software, data, and AI</span>, turning messy, real-world data into tools people actually use.</p>
            <p>I&rsquo;ve built AI reporting tools and executive dashboards at <span class="lite">Lockheed Martin</span>, designed data pipelines for research at the <span class="lite">World Wildlife Fund</span>, and trained and shipped <span class="lite">on-device vision models</span> in my own apps. Through all of this, I&rsquo;ve learned that I really care about the small details most people never notice, like the easing curve on an animation or a good empty state. And when I&rsquo;m not building, I&rsquo;m usually organizing something. I&rsquo;ve come to realize my favorite thing is starting projects that bring people together.</p>
            <div class="chips" style="margin-top:24px;">
              <span class="tag">Python</span>
              <span class="tag">PyTorch</span>
              <span class="tag">CoreML / Vision</span>
              <span class="tag">LLMs / RAG</span>
              <span class="tag">embeddings</span>
              <span class="tag">SQL</span>
              <span class="tag">ML pipelines</span>
              <span class="tag">Swift</span>
            </div>
          </div>

          <aside class="sidecard reveal" data-delay="1">
            <div class="side-block">
              <div class="label">/ stack</div>
              <div class="stack-list">
                <div class="stack-row"><span class="name">Python / PyTorch</span><span class="meter"><i class="on"></i><i class="on"></i><i class="on"></i><i class="on"></i></span></div>
                <div class="stack-row"><span class="name">On-device ML / CoreML</span><span class="meter"><i class="on v"></i><i class="on v"></i><i class="on v"></i><i class="on v"></i></span></div>
                <div class="stack-row"><span class="name">LLMs / RAG apps</span><span class="meter"><i class="on"></i><i class="on"></i><i class="on"></i><i></i></span></div>
                <div class="stack-row"><span class="name">Data &amp; ML pipelines</span><span class="meter"><i class="on v"></i><i class="on v"></i><i class="on v"></i><i class="on v"></i></span></div>
                <div class="stack-row"><span class="name">SQL / analytics</span><span class="meter"><i class="on"></i><i class="on"></i><i class="on"></i><i></i></span></div>
              </div>
            </div>
            <div class="side-block">
              <div class="label">/ education</div>
              <div class="edu-row"><span class="yr">2024&ndash;28</span><span class="what">B.S. Computer &amp; Information Technology + B.S. Economics, AI focus, at <b style="color:var(--text-2)">Purdue University</b>. GPA 3.72.</span></div>
            </div>
            <div class="side-block">
              <div class="label">/ leadership</div>
              <div class="edu-row"><span class="yr">2025&ndash;</span><span class="what">Head Climbing Officer, <b style="color:var(--text-2)">Purdue Outing Club</b>: ran a 150+ climber competition, secured $7K+ recurring funding.</span></div>
              <div class="edu-row"><span class="yr">2025&ndash;</span><span class="what">Technology Committee, <b style="color:var(--text-2)">Alpha Kappa Psi</b>: tools and workshops for 100+ members.</span></div>
              <div class="edu-row"><span class="yr">2017</span><span class="what"><b style="color:var(--text-2)">Eagle Scout</b>: led 20 volunteers on a self-funded community build.</span></div>
            </div>
            <div class="side-block">
              <div class="label">/ now</div>
              <div class="edu-row"><span class="yr" style="color:var(--green)">●</span><span class="what">AI + Cloud intern at Lockheed Martin, consulting at Boilermaker Consulting, and building DeDuper 2.0.</span></div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ===================== CONTACT ===================== -->
    <section class="contact" id="contact" data-screen-label="Contact" aria-label="Contact">
      <div class="container">
        <div class="glowbox reveal">
          <span class="eyebrow" style="justify-content:center;">get in touch</span>
          <h2 style="margin-top:18px;">Let&rsquo;s build<br />something <span class="grad">good.</span></h2>
          <p class="lead">Whether you&rsquo;re recruiting, want to build something together, or just want to talk about on-device AI, I&rsquo;d love to hear from you. Even a short conversation would mean a lot.</p>
          <div class="contact-cta" style="flex-direction:column; gap:10px;">
            <span style="font-family:var(--mono); font-size:1.05rem; color:var(--text-2);">siddharthdbobba [at] gmail [dot] com</span>
            <span style="font-family:var(--mono); font-size:1.05rem; color:var(--text-2);">bobba0 [at] purdue [dot] edu</span>
          </div>
          <div class="social-row">
            <a href="https://github.com/siddharthdbobba" class="social" target="_blank" rel="noopener">GitHub</a>
            <a href="https://www.linkedin.com/in/siddharth-bobba" class="social" target="_blank" rel="noopener">LinkedIn</a>
            <a href="https://x.com/SDBobba" class="social" target="_blank" rel="noopener">X @SDBobba</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <span class="brand">sb_</span>
      <span>&copy; 2026 Siddharth Bobba</span>
      <span><a href="#top">back to top &uarr;</a></span>
    </div>
  </footer>

  <script is:inline>
    /* ----- build abstract project covers (simple geometric motifs only) ----- */
    // Sticker Map — scattered round stickers
    (function () {
      var el = document.getElementById("cover-sticker");
      if (!el) return;
      var svgNS = "http://www.w3.org/2000/svg";
      var svg = document.createElementNS(svgNS, "svg");
      svg.setAttribute("viewBox", "0 0 400 230");
      svg.setAttribute("width", "100%"); svg.setAttribute("height", "100%");
      // faint grid "map"
      for (var x = 0; x <= 400; x += 40) addLine(x, 0, x, 230, 0.05);
      for (var y = 0; y <= 230; y += 40) addLine(0, y, 400, y, 0.05);
      var spots = [[90,70,16,"#5b8cff"],[180,130,22,"#9b6bff"],[270,80,14,"#5b8cff"],[320,160,18,"#3b82f6"],[140,170,12,"#9b6bff"],[230,55,10,"#5b8cff"]];
      spots.forEach(function (s) {
        var c = document.createElementNS(svgNS, "circle");
        c.setAttribute("cx", s[0]); c.setAttribute("cy", s[1]); c.setAttribute("r", s[2]);
        c.setAttribute("fill", s[3]); c.setAttribute("opacity", "0.85");
        c.setAttribute("stroke", "#0b0b12"); c.setAttribute("stroke-width", "3");
        svg.appendChild(c);
      });
      el.appendChild(svg);
      function addLine(x1,y1,x2,y2,o){var l=document.createElementNS(svgNS,"line");l.setAttribute("x1",x1);l.setAttribute("y1",y1);l.setAttribute("x2",x2);l.setAttribute("y2",y2);l.setAttribute("stroke","#5b8cff");l.setAttribute("stroke-opacity",o);svg.appendChild(l);}
    })();

    // World Cup Predictor — bracket lines
    (function () {
      var el = document.getElementById("cover-bracket");
      if (!el) return;
      var svgNS = "http://www.w3.org/2000/svg";
      var svg = document.createElementNS(svgNS, "svg");
      svg.setAttribute("viewBox", "0 0 400 230");
      svg.setAttribute("width", "100%"); svg.setAttribute("height", "100%");
      function seg(d, o, c){var p=document.createElementNS(svgNS,"path");p.setAttribute("d",d);p.setAttribute("fill","none");p.setAttribute("stroke",c||"#5b8cff");p.setAttribute("stroke-width","2");p.setAttribute("stroke-opacity",o);svg.appendChild(p);}
      // left bracket
      seg("M30 40 H90 V70 H120", 0.5);
      seg("M30 100 H90 V70", 0.5);
      seg("M30 140 H90 V170 H120", 0.5);
      seg("M30 200 H90 V170", 0.5);
      // center
      seg("M120 70 H180 V120 H220", 0.85, "#9b6bff");
      seg("M120 170 H180 V120", 0.85, "#9b6bff");
      // right mirror
      seg("M370 40 H310 V70 H280", 0.5);
      seg("M370 100 H310 V70", 0.5);
      seg("M370 140 H310 V170 H280", 0.5);
      seg("M370 200 H310 V170", 0.5);
      seg("M280 70 H220 V120", 0.85, "#9b6bff");
      seg("M280 170 H220 V120", 0.85, "#9b6bff");
      // trophy node
      var c=document.createElementNS(svgNS,"circle");c.setAttribute("cx","220");c.setAttribute("cy","120");c.setAttribute("r","9");c.setAttribute("fill","#9b6bff");svg.appendChild(c);
      el.appendChild(svg);
    })();

    // Trips — route path with nodes
    (function () {
      var el = document.getElementById("cover-trips");
      if (!el) return;
      var svgNS = "http://www.w3.org/2000/svg";
      var svg = document.createElementNS(svgNS, "svg");
      svg.setAttribute("viewBox", "0 0 400 230");
      svg.setAttribute("width", "100%"); svg.setAttribute("height", "100%");
      var path = document.createElementNS(svgNS, "path");
      path.setAttribute("d", "M40 180 C 110 80, 150 200, 210 120 S 320 40, 360 90");
      path.setAttribute("fill", "none");
      path.setAttribute("stroke", "#5b8cff");
      path.setAttribute("stroke-width", "2.5");
      path.setAttribute("stroke-dasharray", "6 7");
      path.setAttribute("stroke-opacity", "0.8");
      svg.appendChild(path);
      [[40,180,"#9b6bff"],[210,120,"#5b8cff"],[360,90,"#9b6bff"]].forEach(function (n) {
        var c = document.createElementNS(svgNS, "circle");
        c.setAttribute("cx", n[0]); c.setAttribute("cy", n[1]); c.setAttribute("r", "7");
        c.setAttribute("fill", n[2]); c.setAttribute("stroke", "#0b0b12"); c.setAttribute("stroke-width", "3");
        svg.appendChild(c);
      });
      el.appendChild(svg);
    })();
  </script>
  <script is:inline>
/* =================================================================
   sb_ portfolio — interactions
   Vanilla JS. Respects prefers-reduced-motion. Mobile = simplified.
   ================================================================= */
(function () {
  "use strict";
  var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  var coarse = window.matchMedia("(pointer: coarse)").matches;
  var mobile = window.matchMedia("(max-width: 720px)").matches;

  /* ---------- nav scrolled state ---------- */
  var nav = document.querySelector(".nav");
  function onScroll() {
    if (window.scrollY > 24) nav.classList.add("scrolled");
    else nav.classList.remove("scrolled");
  }
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  /* ---------- cursor-following glow ---------- */
  var glow = document.getElementById("cursor-glow");
  if (glow && !coarse) {
    var gx = window.innerWidth / 2, gy = window.innerHeight / 2, cx = gx, cy = gy, raf;
    window.addEventListener("pointermove", function (e) {
      gx = e.clientX; gy = e.clientY;
      glow.style.opacity = "1";
      if (!raf) loop();
    });
    function loop() {
      cx += (gx - cx) * 0.12;
      cy += (gy - cy) * 0.12;
      glow.style.transform = "translate(" + cx + "px," + cy + "px) translate(-50%,-50%)";
      if (Math.abs(gx - cx) > 0.4 || Math.abs(gy - cy) > 0.4) raf = requestAnimationFrame(loop);
      else raf = null;
    }
  }

  /* ---------- typed tagline ---------- */
  (function typed() {
    var el = document.getElementById("typed");
    var cur = document.getElementById("typed-cursor");
    if (!el) return;
    var lines = [
      "I build at the intersection of software, data, and AI.",
      "Python · PyTorch · CoreML · LLMs · SQL · ML pipelines",
      "Right now: AI + Cloud @ Lockheed Martin, consulting, and DeDuper 2.0."
    ];
    if (reduce) { el.textContent = lines[0]; return; }
    var li = 0, ci = 0, deleting = false;
    function tick() {
      var line = lines[li];
      if (!deleting) {
        ci++;
        el.textContent = line.slice(0, ci);
        if (ci >= line.length) { deleting = true; return setTimeout(tick, 2200); }
        setTimeout(tick, 38 + Math.random() * 40);
      } else {
        ci--;
        el.textContent = line.slice(0, ci);
        if (ci <= 0) { deleting = false; li = (li + 1) % lines.length; return setTimeout(tick, 320); }
        setTimeout(tick, 18);
      }
    }
    setTimeout(tick, 650);
  })();

  /* ---------- hero inference field ---------- */
  (function inferenceField() {
    var canvas = document.getElementById("hero-canvas");
    if (!canvas) return;
    var ctx = canvas.getContext("2d");
    var W, H, DPR = Math.min(window.devicePixelRatio || 1, 2);
    var pts = [];
    var count = mobile ? 26 : 60;
    var mouse = { x: -9999, y: -9999 };
    var BLUE = [91, 140, 255], VIOLET = [155, 107, 255];

    function resize() {
      var w = canvas.clientWidth, h = canvas.clientHeight;
      if (w <= 0 || h <= 0) return false;        // not laid out yet
      if (w === W && h === H) return false;       // no change
      W = w; H = h;
      canvas.width = Math.round(W * DPR);
      canvas.height = Math.round(H * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      return true;
    }

    function rnd(a, b) { return a + Math.random() * (b - a); }

    function makePoints() {
      pts = [];
      for (var i = 0; i < count; i++) {
        var dup = Math.random() < 0.34;
        pts.push({
          x: rnd(0, W), y: rnd(0, H),
          vx: rnd(-0.18, 0.18), vy: rnd(-0.18, 0.18),
          r: rnd(1.3, 2.8),
          dup: dup,
          c: dup ? VIOLET : BLUE,
          partner: null,
          merge: 0
        });
      }
      // pair up duplicates
      var dups = pts.filter(function (p) { return p.dup; });
      for (var j = 0; j + 1 < dups.length; j += 2) {
        dups[j].partner = dups[j + 1];
        dups[j + 1].partner = dups[j];
      }
    }

    function step() {
      ctx.clearRect(0, 0, W, H);
      // links between near points
      for (var i = 0; i < pts.length; i++) {
        for (var k = i + 1; k < pts.length; k++) {
          var a = pts[i], b = pts[k];
          var dx = a.x - b.x, dy = a.y - b.y;
          var d2 = dx * dx + dy * dy;
          if (d2 < 12000) {
            var al = (1 - d2 / 12000) * 0.16;
            ctx.strokeStyle = "rgba(91,140,255," + al + ")";
            ctx.lineWidth = 1;
            ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
          }
        }
      }
      for (var p, n = 0; n < pts.length; n++) {
        p = pts[n];
        // duplicate attraction → merge → respawn
        if (p.partner) {
          var px = p.partner.x - p.x, py = p.partner.y - p.y;
          var pd = Math.sqrt(px * px + py * py) || 1;
          if (pd < 90) { p.vx += (px / pd) * 0.006; p.vy += (py / pd) * 0.006; }
          if (pd < 14) {
            p.merge += 0.04;
            if (p.merge > 1) {
              // respawn both
              p.x = rnd(0, W); p.y = rnd(0, H); p.merge = 0;
              p.partner.x = rnd(0, W); p.partner.y = rnd(0, H); p.partner.merge = 0;
            }
          }
        }
        // cursor repel
        var mx = p.x - mouse.x, my = p.y - mouse.y;
        var md = mx * mx + my * my;
        if (md < 16000) {
          var f = (1 - md / 16000) * 0.7;
          var mdist = Math.sqrt(md) || 1;
          p.vx += (mx / mdist) * f * 0.25;
          p.vy += (my / mdist) * f * 0.25;
        }
        p.x += p.vx; p.y += p.vy;
        p.vx *= 0.97; p.vy *= 0.97;
        // gentle drift floor
        if (Math.abs(p.vx) < 0.04) p.vx += rnd(-0.04, 0.04);
        if (Math.abs(p.vy) < 0.04) p.vy += rnd(-0.04, 0.04);
        // wrap
        if (p.x < -10) p.x = W + 10; if (p.x > W + 10) p.x = -10;
        if (p.y < -10) p.y = H + 10; if (p.y > H + 10) p.y = -10;
        // draw
        var glowAmt = p.dup ? 0.5 + p.merge * 0.5 : 0.5;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r + p.merge * 2, 0, 6.2832);
        ctx.fillStyle = "rgba(" + p.c[0] + "," + p.c[1] + "," + p.c[2] + "," + (0.5 + glowAmt * 0.4) + ")";
        ctx.shadowColor = "rgba(" + p.c[0] + "," + p.c[1] + "," + p.c[2] + ",0.9)";
        ctx.shadowBlur = 8;
        ctx.fill();
        ctx.shadowBlur = 0;
      }
      animId = requestAnimationFrame(step);
    }

    var animId = null, running = false;
    function start() { if (!running) { running = true; step(); } }
    function stop() { if (animId) cancelAnimationFrame(animId); animId = null; running = false; }

    function remeasure() {
      if (resize()) { makePoints(); return true; }
      return false;
    }

    var hero = document.querySelector(".hero");

    // initial measure — defer until layout settles, retry until we get a real width
    function initMeasure(tries) {
      if (remeasure() || tries <= 0) { afterReady(); return; }
      requestAnimationFrame(function () { initMeasure(tries - 1); });
    }

    // keep bitmap in sync with the element's real box
    if ("ResizeObserver" in window) {
      var ro = new ResizeObserver(function () { remeasure(); });
      ro.observe(canvas);
    }
    window.addEventListener("resize", remeasure);
    window.addEventListener("load", remeasure);

    hero.addEventListener("pointermove", function (e) {
      var r = canvas.getBoundingClientRect();
      mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top;
    });
    hero.addEventListener("pointerleave", function () { mouse.x = -9999; mouse.y = -9999; });

    function afterReady() {
      if (reduce) {
        if (W && H) step(), stop();   // one static frame
        return;
      }
      var io = new IntersectionObserver(function (ents) {
        ents.forEach(function (en) { if (en.isIntersecting) start(); else stop(); });
      }, { threshold: 0.02 });
      io.observe(hero);
      start();
    }

    initMeasure(20);
  })();

  /* ---------- 3D tilt on cards ---------- */
  if (!coarse && !reduce) {
    document.querySelectorAll("[data-tilt]").forEach(function (card) {
      var max = 7;
      card.addEventListener("pointermove", function (e) {
        var r = card.getBoundingClientRect();
        var px = (e.clientX - r.left) / r.width;
        var py = (e.clientY - r.top) / r.height;
        var rx = (0.5 - py) * max * 2;
        var ry = (px - 0.5) * max * 2;
        card.style.transform = "perspective(900px) rotateX(" + rx + "deg) rotateY(" + ry + "deg) translateY(-4px)";
        card.style.setProperty("--mx", (px * 100) + "%");
        card.style.setProperty("--my", (py * 100) + "%");
      });
      card.addEventListener("pointerleave", function () {
        card.style.transform = "";
      });
    });
  }

  /* ---------- scroll reveal ---------- */
  (function reveals() {
    var els = document.querySelectorAll(".reveal");
    if (reduce || !("IntersectionObserver" in window)) {
      els.forEach(function (el) { el.classList.add("in"); });
      return;
    }
    var io = new IntersectionObserver(function (ents) {
      ents.forEach(function (en) {
        if (en.isIntersecting) { en.target.classList.add("in"); io.unobserve(en.target); }
      });
    }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
    els.forEach(function (el) { io.observe(el); });
  })();

  /* ---------- live clock in status strip ---------- */
  (function clock() {
    var el = document.getElementById("clock");
    if (!el) return;
    function fmt() {
      // owner's local time (San Francisco), correct regardless of the visitor's timezone
      el.textContent = new Date().toLocaleTimeString("en-US", {
        timeZone: "America/Los_Angeles", hour: "2-digit", minute: "2-digit", hour12: false
      }) + " PT";
    }
    fmt(); setInterval(fmt, 10000);
  })();

  /* ---------- live "last commit" from GitHub ---------- */
  (function lastCommit() {
    var el = document.getElementById("last-commit");
    var chip = document.getElementById("commit-chip");
    if (!el || !chip) return;
    fetch("https://api.github.com/users/siddharthdbobba/events/public")
      .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
      .then(function (evs) {
        var push = (evs || []).filter(function (e) { return e.type === "PushEvent"; })[0] || (evs || [])[0];
        if (!push || !push.created_at) return;
        var mins = (Date.now() - new Date(push.created_at).getTime()) / 60000;
        var txt = mins < 60 ? Math.max(1, Math.round(mins)) + "m ago"
                : mins < 1440 ? Math.round(mins / 60) + "h ago"
                : Math.round(mins / 1440) + "d ago";
        el.textContent = txt;
        chip.hidden = false;
      })
      .catch(function () { /* keep chip hidden */ });
  })();

  /* ---------- ⌘S / Ctrl+S jump palette ---------- */
  (function cmdPalette() {
    var NAV_ITEMS = [
      { label: "experience", href: "#experience" },
      { label: "projects",   href: "#work" },
      { label: "trips",      href: "/trips/" },
      { label: "about",      href: "#about" },
      { label: "contact",    href: "#contact" }
    ];

    /* build styles */
    var style = document.createElement("style");
    style.textContent = [
      "#cmd-palette{position:fixed;top:72px;left:50%;transform:translateX(-50%);",
      "z-index:9999;width:min(340px,90vw);background:var(--bg-card,#131320);",
      "border:1px solid var(--border,rgba(255,255,255,.1));border-radius:12px;",
      "box-shadow:0 24px 64px rgba(0,0,0,.6);overflow:hidden;outline:none;}",
      "#cmd-palette ul{margin:0;padding:8px;list-style:none;}",
      "#cmd-palette li a{display:flex;align-items:center;gap:10px;padding:10px 14px;",
      "border-radius:8px;color:var(--text-1,#e8e8e8);text-decoration:none;",
      "font-size:14px;letter-spacing:.02em;}",
      "#cmd-palette li a:hover,#cmd-palette li.active a",
      "{background:rgba(91,140,255,.15);}",
      "#cmd-palette .p-hash{color:#5b8cff;font-size:12px;opacity:.7;}"
    ].join("");
    if (!reduce) {
      style.textContent += [
        "#cmd-palette:not([hidden]){animation:palette-in .12s ease;}",
        "@keyframes palette-in{from{opacity:0;transform:translateX(-50%) translateY(-8px);}",
        "to{opacity:1;transform:translateX(-50%) translateY(0);}}"
      ].join("");
    }
    document.head.appendChild(style);

    /* build DOM */
    var overlay = document.createElement("div");
    overlay.id = "cmd-palette";
    overlay.setAttribute("hidden", "");
    overlay.setAttribute("role", "dialog");
    overlay.setAttribute("aria-modal", "true");
    overlay.setAttribute("aria-label", "Jump to section");
    overlay.tabIndex = -1;

    var ul = document.createElement("ul");
    NAV_ITEMS.forEach(function (item) {
      var li = document.createElement("li");
      var a  = document.createElement("a");
      a.href = item.href;
      a.innerHTML = '<span class="p-hash">#</span>' + item.label;
      li.appendChild(a);
      ul.appendChild(li);
    });
    overlay.appendChild(ul);
    document.body.appendChild(overlay);

    var activeIdx = 0;

    function getItems() { return overlay.querySelectorAll("li"); }

    function setActive(idx) {
      var its = getItems();
      if (!its.length) return;
      activeIdx = (idx + its.length) % its.length;
      its.forEach(function (li) { li.classList.remove("active"); });
      its[activeIdx].classList.add("active");
      its[activeIdx].querySelector("a").focus();
    }

    function open() {
      overlay.removeAttribute("hidden");
      setActive(0);
    }

    function close() {
      overlay.setAttribute("hidden", "");
      getItems().forEach(function (li) { li.classList.remove("active"); });
    }

    function isOpen() { return !overlay.hasAttribute("hidden"); }

    window.addEventListener("keydown", function (e) {
      if ((e.metaKey || e.ctrlKey) && e.key === "s") {
        e.preventDefault();
        if (isOpen()) { close(); } else { open(); }
        return;
      }
      if (!isOpen()) return;
      if (e.key === "Escape")    { e.preventDefault(); close(); return; }
      if (e.key === "ArrowDown") { e.preventDefault(); setActive(activeIdx + 1); return; }
      if (e.key === "ArrowUp")   { e.preventDefault(); setActive(activeIdx - 1); return; }
    });

    document.addEventListener("click", function (e) {
      if (isOpen() && !overlay.contains(e.target)) { close(); }
    });

    overlay.addEventListener("click", function (e) {
      if (e.target.closest("a")) { close(); }
    });
  })();

  /* ---------- blinking favicon (caret toggles ~once/sec) ---------- */
  (function blinkFavicon() {
    var link = document.getElementById("favicon");
    if (!link) return;
    function svg(on) {
      return '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" width="128" height="128">'
        + '<rect x="2" y="2" width="124" height="124" rx="27" fill="#0a0a0a" stroke="#2b2b2b" stroke-width="2"/>'
        + '<text x="42" y="60" font-family="ui-monospace, monospace" font-size="54" font-weight="700" text-anchor="middle" dominant-baseline="central">'
        + '<tspan fill="#e8e8e8">s</tspan><tspan fill="#3b82f6">b</tspan></text>'
        + '<rect x="69" y="86" width="24" height="9" rx="2" fill="#3b82f6" opacity="' + (on ? "1" : "0") + '"/>'
        + '</svg>';
    }
    function uri(on) { return "data:image/svg+xml," + encodeURIComponent(svg(on)); }
    if (reduce) { link.href = uri(true); return; }
    var on = true;
    link.href = uri(true);
    setInterval(function () { on = !on; link.href = uri(on); }, 560);
  })();
})();
  </script>
</body>
</html>
