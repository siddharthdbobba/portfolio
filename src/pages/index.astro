---
import Base from "../layouts/Base.astro";
import AppIcon from "../components/AppIcon.astro";
import MediaPlaceholder from "../components/MediaPlaceholder.astro";
---

<Base title="Siddharth Bobba">
  <main>

    <!-- ─── Hero ──────────────────────────────────────────────────────── -->
    <section class="section hero-section">
      <div class="container reveal">
        <div class="hero-eyebrow mono muted">student · developer</div>
        <h1>Siddharth<br /><span class="gradient-text">Bobba</span></h1>
        <p class="lead" style="margin-top: 20px; max-width: 520px;">
          Purdue student studying CIT and Economics with a focus on AI. I ship
          native macOS and iOS apps — most recently DeDuper, on-device AI that
          cleans up your photo library.
        </p>
        <div class="hero-links">
          <a class="btn btn-primary" href="/#projects">See my work</a>
          <a class="btn btn-secondary" href="https://linkedin.com/in/siddharth-bobba" target="_blank" rel="noopener">LinkedIn</a>
          <a class="btn btn-secondary" href="https://github.com/siddharthdbobba" target="_blank" rel="noopener">GitHub</a>
        </div>
        <div class="hero-now">
          <span class="mono muted">now building</span>
          <AppIcon label="DeDuper" size={28} radius={8}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="13" height="13" rx="2" />
              <path d="M8 21h11a2 2 0 0 0 2-2V8" />
            </svg>
          </AppIcon>
          <AppIcon label="Sticker Map" size={28} radius={8}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 21s-6-5.3-6-10a6 6 0 0 1 12 0c0 4.7-6 10-6 10Z" />
              <circle cx="12" cy="11" r="2" />
            </svg>
          </AppIcon>
        </div>
      </div>
    </section>

    <!-- ─── Projects ──────────────────────────────────────────────────── -->
    <section class="section" id="projects">
      <div class="container">
        <h2 class="reveal" style="margin-bottom: 32px;">Projects</h2>

        <a class="card project-card reveal" href="/deduper">
          <MediaPlaceholder label="DeDuper screenshot coming soon_" ratio="16 / 9" />
          <div class="project-header" style="margin-top: 16px;">
            <AppIcon label="DeDuper" size={46}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="13" height="13" rx="2" />
                <path d="M8 21h11a2 2 0 0 0 2-2V8" />
              </svg>
            </AppIcon>
            <div class="project-meta">
              <h3>DeDuper</h3>
              <span class="mono muted" style="font-size: 0.8rem;">macOS · iOS</span>
            </div>
            <div class="project-arrow">→</div>
          </div>
          <p style="margin-top: 12px;">
            Find and remove duplicate photos from your library using on-device AI.
            Supports Photos.app, local folders, and AI-powered close-call resolution.
          </p>
          <div class="project-tags" style="margin-top: 16px;">
            <span class="tag">Swift</span>
            <span class="tag">SwiftUI</span>
            <span class="tag">CoreImage</span>
            <span class="tag">StoreKit</span>
            <span class="tag">AI</span>
          </div>
        </a>

        <a class="card project-card reveal" href="https://stickers.siddharthbobba.com" target="_blank" rel="noopener" style="margin-top: 16px; transition-delay: 0.08s;">
          <MediaPlaceholder label="Sticker Map preview coming soon_" ratio="16 / 9" />
          <div class="project-header" style="margin-top: 16px;">
            <AppIcon label="Sticker Map" size={46}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 21s-6-5.3-6-10a6 6 0 0 1 12 0c0 4.7-6 10-6 10Z" />
                <circle cx="12" cy="11" r="2" />
              </svg>
            </AppIcon>
            <div class="project-meta">
              <h3>Sticker Map</h3>
              <span class="mono muted" style="font-size: 0.8rem;">Purdue Outing Club</span>
            </div>
            <div class="project-arrow">↗</div>
          </div>
          <p style="margin-top: 12px;">
            An interactive map of every place a Purdue Outing Club sticker has landed.
            Click a marker for the photo and story behind each sighting.
          </p>
          <div class="project-tags" style="margin-top: 16px;">
            <span class="tag">Astro</span>
            <span class="tag">React</span>
            <span class="tag">Leaflet</span>
            <span class="tag">Maps</span>
          </div>
        </a>

        <a class="card trips-teaser reveal" href="/trips" style="margin-top: 16px; transition-delay: 0.12s;">
          <div class="trips-teaser__text">
            <h3>Trips</h3>
            <p class="mono muted" style="font-size: 0.8rem; margin-top: 2px;">photos &amp; field notes from the road</p>
          </div>
          <span class="trips-teaser__arrow" aria-hidden="true">→</span>
        </a>

        <div class="more-hint">
          <p class="mono muted" style="font-size: 0.85rem;">more coming soon_</p>
        </div>
      </div>
    </section>

    <!-- ─── About ──────────────────────────────────────────────────────── -->
    <section class="section" id="about">
      <div class="container about-grid reveal">
        <div>
          <h2 style="margin-bottom: 20px;">About</h2>
          <p style="margin-bottom: 14px;">
            I'm a student at <strong style="color: var(--text);">Purdue University</strong>
            studying Computer & Information Technology and Economics, with a focus on
            artificial intelligence.
          </p>
          <p style="margin-bottom: 14px;">
            I build native macOS and iOS apps using Swift and SwiftUI. I care about
            making software that's fast, private, and actually useful.
          </p>
          <p>
            When I'm not studying or building, I'm thinking about how AI can be
            embedded into everyday tools without getting in the way.
          </p>
        </div>
        <div class="about-sidebar">
          <h3 class="sidebar-label">Stack</h3>
          <ul class="stack-list">
            <li>Swift · SwiftUI</li>
            <li>Python</li>
            <li>Cloudflare Workers</li>
            <li>AI / LLM integration</li>
          </ul>
          <h3 class="sidebar-label" style="margin-top: 24px;">Education</h3>
          <p style="color: var(--text); font-size: 0.9rem;">Purdue University</p>
          <p style="font-size: 0.85rem;">B.S. Computer & Information Technology</p>
          <p style="font-size: 0.85rem;">B.S. Economics</p>
        </div>
      </div>
    </section>

    <!-- ─── Contact ──────────────────────────────────────────────────────── -->
    <section class="section" id="contact">
      <div class="container contact-block reveal">
        <h2 style="margin-bottom: 12px;">Get in touch</h2>
        <p style="max-width: 460px; margin: 0 auto 28px;">
          Have a project in mind, a question, or just want to say hi?
          My inbox is always open.
        </p>
        <div class="hero-links" style="justify-content: center;">
          <a class="btn btn-primary" href="mailto:siddharthdbobba@gmail.com">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="m3 7 9 6 9-6" />
            </svg>
            Email me
          </a>
          <a class="btn btn-secondary" href="https://linkedin.com/in/siddharth-bobba" target="_blank" rel="noopener">LinkedIn</a>
          <a class="btn btn-secondary" href="https://github.com/siddharthdbobba" target="_blank" rel="noopener">GitHub</a>
        </div>
        <a class="contact-email mono muted link-accent" href="mailto:siddharthdbobba@gmail.com">siddharthdbobba@gmail.com</a>
      </div>
    </section>

  </main>
</Base>

<style>
  .hero-section  { padding-top: 96px; padding-bottom: 80px; }
  .hero-eyebrow  { margin-bottom: 16px; font-size: 0.85rem; letter-spacing: 0.05em; }
  .hero-links    { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 32px; }
  .hero-now { display: flex; align-items: center; gap: 10px; margin-top: 28px; }
  .hero-now > span { font-size: 0.8rem; letter-spacing: 0.04em; }

  .project-card  { display: block; }
  .project-header { display: flex; align-items: center; gap: 14px; }
  .project-meta  { flex: 1; }
  .project-arrow { color: var(--muted); font-size: 1.2rem; transition: transform 0.15s; }
  .project-card:hover .project-arrow { transform: translateX(4px); }
  .project-tags  { display: flex; flex-wrap: wrap; gap: 6px; }
  .more-hint     { padding: 28px 0 4px; }
  .trips-teaser { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .trips-teaser__arrow { color: var(--muted); font-size: 1.2rem; transition: transform 0.15s; }
  .trips-teaser:hover .trips-teaser__arrow { transform: translateX(4px); color: var(--accent); }

  .contact-block { text-align: center; }
  .contact-email { display: inline-block; margin-top: 20px; }

  .about-grid    { display: grid; grid-template-columns: 1fr 220px; gap: 48px; align-items: start; }
  .about-sidebar { }
  .sidebar-label {
    color: var(--muted); font-size: 0.8rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    margin-bottom: 12px;
  }
  .stack-list    { list-style: none; display: flex; flex-direction: column; gap: 8px; font-size: 0.9rem; color: var(--text); }

  @media (max-width: 600px) {
    .about-grid   { grid-template-columns: 1fr; }
    .hero-section { padding-top: 56px; }
  }
</style>
